{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],

    /* Path Aliases (Fixes the deprecation & relative paths!) */
    "paths": {
      "@/*": ["./src/*"]                  /* Notice the "./" added here */
    },

    /* Strictness & Safety */
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}