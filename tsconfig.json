{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",                  /* Changed from NodeNext */
    "moduleResolution": "bundler",        /* Changed from NodeNext */
    "customConditions": ["module"],
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}